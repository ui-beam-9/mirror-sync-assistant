# ====================================
# Lark 应用配置
# ====================================

# Lark App ID（在 Lark 开放平台应用详情页获取）
# 开放平台地址: https://open.larksuite.com/
LARK_APP_ID=cli_xxxxxxxxxxxxx

# Lark App Secret（在 Lark 开放平台应用详情页获取）
LARK_APP_SECRET=your_app_secret_here

# Lark Verification Token（在 Lark 开放平台事件订阅页面获取）
LARK_VERIFICATION_TOKEN=your_verification_token_here

# Lark Encrypt Key（消息加密密钥，在 Lark 开放平台事件订阅页面获取）
# 如果不启用加密，可以留空（但建议启用）
LARK_ENCRYPT_KEY=your_encrypt_key_here

# Lark API 域名
# 国际版 Lark（默认）: https://open.larksuite.com
# 中国版飞书: https://open.feishu.cn
LARK_API_DOMAIN=https://open.larksuite.com

# ====================================
# GitHub 配置
# ====================================

# GitHub Personal Access Token
# 需要具有 repo 权限，用于创建 Issues
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub 仓库（格式: owner/repo）
# 例如: ui-beam-9/docker-images-sync-huaweicloud-swr
GITHUB_REPO=owner/repo

# ====================================
# 服务器配置
# ====================================

# 服务器监听端口（默认 8081，避免与企业微信服务器 8080 冲突）
PORT=8081

# Webhook 验证密钥（用于 GitHub Actions 调用通知接口时验证身份）
# 请生成一个随机字符串，至少 32 位，并在 GitHub Secrets 中同步配置
WEBHOOK_SECRET=your_random_webhook_secret_at_least_32_chars
